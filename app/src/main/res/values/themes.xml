<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Tacticore" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="roundedImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="RoundedSearchBox" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceLargeCorner</item>
    </style>

    <style name="ShapeAppearanceLargeCorner">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="NavMenuItemText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="CustomPopupMenu" parent="@style/Widget.AppCompat.PopupMenu">
        <item name="android:textColor">@color/drawer_text</item>
        <item name="android:itemBackground">@color/drawer_background</item>
        <item name="android:colorControlNormal">@color/drawer_text</item>
    </style>
    <style name="Theme.Tacticore.Splash" parent="Theme.Tacticore">
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>